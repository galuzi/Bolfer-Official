Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule .* - [E=HTTPS_AUTHORIZATION:%{HTTPS:Authorization}]

  # Depois de ativar o SSL na KingHost, descomente para forcar HTTPS.
  # RewriteCond %{HTTPS} !=on
  # RewriteCond %{HTTPS:X-Forwarded-Proto} !https [NC]
  # RewriteRule ^ https://%{HTTPS_HOST}%{REQUEST_URI} [L,R=301]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [L,QSA]
</IfModule>

<FilesMatch "^\.">
  Require all denied
</FilesMatch>
